                        51 => 'setting_form',
                    ];

                    // Loop through the user role permissions and set the forms
                    foreach ($userRolePermissions as $userRolePermission) {
                        if (isset($formMapping[$userRolePermission['form_menu_id']])) {
                            $form = $formMapping[$userRolePermission['form_menu_id']];
                            $$form = '';
                        }
                    }
                }

