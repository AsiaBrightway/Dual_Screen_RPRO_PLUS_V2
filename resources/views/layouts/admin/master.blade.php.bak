                foreach ($forms as $form) {
                    $$form = 'd-none';
                }

                // If user role ID is 1, set all forms to visible
                if ($userRoleID == 1) {
                    foreach ($forms as $form) {
                        $$form = '';
                    }
                } else {
                    // Create a mapping array for form_menu_id to form variables
                    $formMapping = [
                        1 => 'dashboard_form',
                        2 => 'store_form',
                        3 => 'store_dineIn_form',
                        4 => 'store_saleLists_form',
                        5 => 'store_reservation_form',
