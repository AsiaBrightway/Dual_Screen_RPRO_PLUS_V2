    public function salesReport()
    {
        $todayDate = Carbon::now()->format('Y-m-d');
        $sales = Sales::select('*', 'waiter.name as waiter_name', 'cashier.name as cashier_name')
            ->join('tables', 'sales.table_id', 'tables.table_id')
            ->join('floors', 'tables.floor_id', 'floors.floor_id')
            ->join('customers', 'sales.customer_id', 'customers.customer_id')
            ->join('users as waiter', 'sales.waiter_id', 'waiter.id')
            ->join('users as cashier', 'sales.cashier_id', 'cashier.id')
            ->where('sales.is_delete', 0)
            ->whereDate('sales.created_at', $todayDate)
            ->get()
            ->sortByDesc('sale_id')
            ->toArray();

        return view('admin.reports.sales.sales_report', compact('sales'));
    }
    public function salesReportBySearch(Request $req)
    {
        $startDate = $req->query('startDate');
        $endDate = $req->query('endDate');
        $endDate = date('Y-m-d', strtotime($endDate . ' +1 day'));

        $searchCategoryID = $req->query('searchCategoryID');
        $searchStockID = $req->query('searchStockID');
        $searchEmployeeID = $req->query('searchEmployeeID');
        $searchDeletedOrderID = $req->query('searchDeletedOrderID');
        $isCheckedItemSummary = $req->query('isCheckedItemSummary');
        $isFOCSummary = $req->query('isFOCSummary');
        $isDiscountSummary = $req->query('isDiscountSummary');
        $isKPaySummary = $req->query('isKPaySummary');
        $isDeletedSummary = $req->query('isDeletedSummary');

        $sales_report_list = [];

        if ($isCheckedItemSummary == 1) {
            if ($searchCategoryID == 0 && $searchStockID == 0 && $searchEmployeeID == 0 && $isFOCSummary==0) {
                $sales_report_list = SalesDetail::join('menu_items as items1', 'sales_details.item_id', '=', 'items1.item_id')
                    ->join('units', 'units.unit_id', '=', 'items1.unit_id')
                    ->join('users as U', 'sales_details.ordered_by', 'U.id')
                    ->join('menu_categories as MC', 'items1.sub_category_id', 'MC.category_id')
                    ->join('sales as S', 'sales_details.sale_id', 'S.sale_id')
                    ->join('item_selling_prices as ISP', 'items1.item_id', 'ISP.item_id')
                    ->where('sales_details.created_at', '>=', date($startDate))
                    ->where('sales_details.created_at', '<=', date($endDate))
                    ->get()
                    ->toArray();
            }
            if ($searchCategoryID != 0) {
                $sales_report_list = SalesDetail::join('menu_items as items1', 'sales_details.item_id', '=', 'items1.item_id')
                    ->join('units', 'units.unit_id', '=', 'items1.unit_id')
                    ->join('users as U', 'sales_details.ordered_by', 'U.id')
                    ->join('menu_categories as MC', 'items1.sub_category_id', 'MC.category_id')
                    ->join('sales as S', 'sales_details.sale_id', 'S.sale_id')
                    ->join('item_selling_prices as ISP', 'items1.item_id', 'ISP.item_id')
                    ->where('sales_details.created_at', '>=', date($startDate))
                    ->where('sales_details.created_at', '<=', date($endDate))
                    ->where('items1.sub_category_id', $searchCategoryID)
                    ->get()
                    ->toArray();
            }
            if ($searchStockID != 0) {
                $sales_report_list = SalesDetail::join('menu_items as items1', 'sales_details.item_id', '=', 'items1.item_id')
                    ->join('units', 'units.unit_id', '=', 'items1.unit_id')
                    ->join('users as U', 'sales_details.ordered_by', 'U.id')
                    ->join('menu_categories as MC', 'items1.sub_category_id', 'MC.category_id')
                    ->join('sales as S', 'sales_details.sale_id', 'S.sale_id')
                    ->join('item_selling_prices as ISP', 'items1.item_id', 'ISP.item_id')
                    ->where('sales_details.created_at', '>=', date($startDate))
                    ->where('sales_details.created_at', '<=', date($endDate))
                    ->where('items1.item_id', $searchStockID)
                    ->get()
                    ->toArray();
            }

            if ($searchEmployeeID != 0) {
                $sales_report_list = SalesDetail::join('menu_items as items1', 'sales_details.item_id', '=', 'items1.item_id')
                    ->join('units', 'units.unit_id', '=', 'items1.unit_id')
                    ->join('users as U', 'sales_details.ordered_by', 'U.id')
                    ->join('menu_categories as MC', 'items1.sub_category_id', 'MC.category_id')
                    ->join('sales as S', 'sales_details.sale_id', 'S.sale_id')
                    ->join('item_selling_prices as ISP', 'items1.item_id', 'ISP.item_id')
                    ->where('sales_details.created_at', '>=', date($startDate))
                    ->where('sales_details.created_at', '<=', date($endDate))
                    ->where('U.id', $searchEmployeeID)
                    ->get()
                    ->toArray();
            }
            if ($searchDeletedOrderID != 0) {
                $sales_report_list="";
                $sales_report_list = SalesDetail::join('menu_items as items1', 'sales_details.item_id', '=', 'items1.item_id')
                    ->join('units', 'units.unit_id', '=', 'items1.unit_id')
                    ->join('users as U', 'sales_details.ordered_by', 'U.id')
                    ->join('menu_categories as MC', 'items1.sub_category_id', 'MC.category_id')
                    ->join('sales as S', 'sales_details.sale_id', 'S.sale_id')
                    ->join('item_selling_prices as ISP', 'items1.item_id', 'ISP.item_id')
                    ->join('deleted_orders as D', 'items1.item_id', 'D.item_id')
                    ->where('sales_details.created_at', '>=', date($startDate))
                    ->where('sales_details.created_at', '<=', date($endDate))
                    ->get()
                    ->toArray();
                    // $sales_report_list = DeletedOrder::join('menu_items as items1', 'deleted_orders.item_id', '=', 'items1.item_id')
                    // ->join('units', 'units.unit_id', '=', 'items1.unit_id')
                    // ->join('users as U', 'deleted_orders.ordered_by', 'U.id')
                    // ->join('menu_categories as MC', 'items1.sub_category_id', 'MC.category_id')
                    // ->join('sales as S', 'deleted_orders.order_id', 'S.sale_id')
                    // ->join('item_selling_prices as ISP', 'items1.item_id', 'ISP.item_id')
                    // // ->join('deleted_orders as D', 'items1.item_id', 'D.item_id')
                    // ->where('deleted_orders.updated_at', '>=', date($startDate))
                    // ->where('deleted_orders.updated_at', '<=', date($endDate))
                    // // ->where('items1.sub_category_id', $searchCategoryID)
                    // ->get()
                    // ->toArray();
            }

        }
        else if ($isFOCSummary !=0) {
                    $sales_report_list = Sales::select('*', 'waiter.name as waiter_name', 'cashier.name as cashier_name')
                        ->join('tables', 'sales.table_id', 'tables.table_id')
                        ->join('floors', 'tables.floor_id', 'floors.floor_id')
                        ->join('customers', 'sales.customer_id', 'customers.customer_id')
                        ->join('users as waiter', 'sales.waiter_id', 'waiter.id')
                        ->join('users as cashier', 'sales.cashier_id', 'cashier.id')
                        ->where('sales.is_delete', '0')
                        ->where('sales.voucher_discount_percent', '>=',100)
                        ->where('sales.created_at', '>=', date($startDate))
                        ->where('sales.created_at', '<=', date($endDate))
                        ->get()
                        ->sortByDesc('sale_id')
                        ->toArray();
        }
        else if ($isDiscountSummary !=0) {
                    $sales_report_list = Sales::select('*', 'waiter.name as waiter_name', 'cashier.name as cashier_name')
                        ->join('tables', 'sales.table_id', 'tables.table_id')
                        ->join('floors', 'tables.floor_id', 'floors.floor_id')
                        ->join('customers', 'sales.customer_id', 'customers.customer_id')
                        ->join('users as waiter', 'sales.waiter_id', 'waiter.id')
                        ->join('users as cashier', 'sales.cashier_id', 'cashier.id')
                        ->where('sales.is_delete', '0')
                        ->where('sales.voucher_discount_percent', '>',0)
                        ->where('sales.voucher_discount_percent', '<',100)
                        ->where('sales.created_at', '>=', date($startDate))
                        ->where('sales.created_at', '<=', date($endDate))
                        ->get()
                        ->sortByDesc('sale_id')
                        ->toArray();
            }
        else if ($isKPaySummary !=0) {
                    $sales_report_list = Sales::select('*', 'waiter.name as waiter_name', 'cashier.name as cashier_name')
                        ->join('tables', 'sales.table_id', 'tables.table_id')
                        ->join('floors', 'tables.floor_id', 'floors.floor_id')
                        ->join('customers', 'sales.customer_id', 'customers.customer_id')
                        ->join('users as waiter', 'sales.waiter_id', 'waiter.id')
                        ->join('users as cashier', 'sales.cashier_id', 'cashier.id')
                        ->where('sales.is_delete', '0')
                        ->where('sales.payment_type_id', '!=', 1)
                        ->where('sales.created_at', '>=', date($startDate))
                        ->where('sales.created_at', '<=', date($endDate))
                        ->get()
                        ->sortByDesc('sale_id')
                        ->toArray();
            }
        else if ($isDeletedSummary !=0) {
                    $sales_report_list = Sales::select('*', 'waiter.name as waiter_name', 'cashier.name as cashier_name')
                        ->join('tables', 'sales.table_id', 'tables.table_id')
                        ->join('floors', 'tables.floor_id', 'floors.floor_id')
                        ->join('customers', 'sales.customer_id', 'customers.customer_id')
                        ->join('users as waiter', 'sales.waiter_id', 'waiter.id')
                        ->join('users as cashier', 'sales.cashier_id', 'cashier.id')
                        ->where('sales.is_delete', '1')
                        ->where('sales.created_at', '>=', date($startDate))
                        ->where('sales.created_at', '<=', date($endDate))
                        ->get()
                        ->sortByDesc('sale_id')
                        ->toArray();
            }
        else
        {
            $sales_report_list = Sales::select('*', 'waiter.name as waiter_name', 'cashier.name as cashier_name')
                    ->join('tables', 'sales.table_id', 'tables.table_id')
                    ->join('floors', 'tables.floor_id', 'floors.floor_id')
                    ->join('customers', 'sales.customer_id', 'customers.customer_id')
                    ->join('users as waiter', 'sales.waiter_id', 'waiter.id')
                    ->join('users as cashier', 'sales.cashier_id', 'cashier.id')
                    ->where('sales.is_delete', '0')
                    ->where('sales.created_at', '>=', date($startDate))
                    ->where('sales.created_at', '<=', date($endDate))
                    ->get()
                    ->sortByDesc('sale_id')
                    ->toArray();
        }
        return response()->json($sales_report_list);
    }

    public function modifySaleReportBySearch(Request $req) {

        $startDate = \Carbon\Carbon::parse($req->query('startDate'))->startOfDay();
        $endDate = \Carbon\Carbon::parse($req->query('endDate'))->endOfDay();

        $searchCategoryID = $req->query('searchCategoryID');
        $searchStockID = $req->query('searchStockID');
        $isCheckedItemSummary = $req->query('isCheckedItemSummary');
        $isFOCSummary = $req->query('isFOCSummary');
        $isDiscountSummary = $req->query('isDiscountSummary');
        $isKPaySummary = $req->query('isKPaySummary');
        $isDeletedSummary = $req->query('isDeletedSummary');
        // $searchEmployeeID = $req->query('searchEmployeeID');
        // $searchDeletedOrderID = $req->query('searchDeletedOrderID');

        if($isCheckedItemSummary == 1) {

            $sales_report_list = SalesDetail::select('S.sale_voucher_number', 'items1.item_name', 'MC.menu_category_name', 'units.unit_name',
                                'ISP.item_selling_price', 'ISP.unit_cost', 'promotion_price', 'quantity', 'is_foc', 'order_time')
                                ->join('menu_items as items1', 'sales_details.item_id', '=', 'items1.item_id')
                                ->join('units', 'units.unit_id', '=', 'items1.unit_id')
                                // ->join('users as U', 'sales_details.ordered_by', 'U.id')
                                ->join('menu_categories as MC', 'items1.sub_category_id', 'MC.category_id')
                                ->join('sales as S', 'sales_details.sale_id', 'S.sale_id')
                                ->join('item_selling_prices as ISP', 'items1.item_id', 'ISP.item_id')
                                ->whereBetween('sales_details.created_at', [$startDate, $endDate]);
            if ($searchCategoryID != 0) {

                $sales_report_list->where('items1.sub_category_id', $searchCategoryID);
            }

            if ($searchStockID != 0) {

                $sales_report_list->where('items1.item_id', $searchStockID);
            }
            $sales_report_list = $sales_report_list->get()->toArray();

        }else{
            $sales_report_list = Sales::select('sale_voucher_number', 'floors.floor_name', 'tables.table_name', 'table_order_number',
                                    'customers.customer_name','waiter.name as waiter_name', 'cashier.name as cashier_name', 'order_date', 'total_amount',
                                    'total_item_promo_amount', 'net_amount', 'paid_amount', 'balance_amount', 'change_amount', 'delivery_charges', 'online_paid')
                                    ->join('tables', 'sales.table_id', 'tables.table_id')
                                    ->join('floors', 'tables.floor_id', 'floors.floor_id')
                                    ->join('customers', 'sales.customer_id', 'customers.customer_id')
                                    ->join('users as waiter', 'sales.waiter_id', 'waiter.id')
                                    ->join('users as cashier', 'sales.cashier_id', 'cashier.id')
                                    ->where('sales.is_delete', '0')
                                    ->whereBetween('sales.created_at', [$startDate, $endDate]);

            if($isFOCSummary != 0) {

                $sales_report_list->where('sales.is_delete', '0')
                                  ->where('sales.voucher_discount_percent', '>=',100);

            }elseif ($isDiscountSummary != 0) {

                $sales_report_list->where('sales.is_delete', '0')
                                  ->whereBetween('sales.voucher_discount_percent', [1, 99]);

            } elseif ($isKPaySummary != 0) {

                $sales_report_list->where('sales.is_delete', '0')
                                ->where('sales.payment_type_id', '!=', 1);

            } elseif ($isDeletedSummary != 0) {

                $sales_report_list->where('sales.is_delete', '1');

            } else {

                $sales_report_list->where('sales.is_delete', '0');
            }

            $sales_report_list = $sales_report_list->orderByDesc('sale_id')->get();
        }
        return response()->json($sales_report_list);
    }
}
