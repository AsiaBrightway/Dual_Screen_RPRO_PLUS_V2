let employee_position_list = document.querySelector(".employee-position-list");
if (localStorage.getItem('showMenu')) {
    // category_list.classList.add("showMenu");
    employee_position_list.parentElement.parentElement.classList.add("showMenu");
    employee_position_list.parentElement.parentElement.parentElement.parentElement.classList.add("showMenu");
}

let employee_position_info_container = document.querySelector('.employee_position_info_container');
if (localStorage.getItem('showEmployeePositionInfoContainer')) {
    employee_position_info_container.classList.add("show_container");
}

let employee_position_list_container = document.querySelector('.employee_position_list_container');
if (localStorage.getItem('showEmployeePositionListContainer')) {
    employee_position_list_container.classList.add("show_container");
}

let employee_position_info_label = document.querySelector('#employee_position_info_label');
employee_position_info_label.addEventListener("click", (e) => {
    employee_position_info_label.classList.toggle('show');
    let employee_position_info_container = document.querySelector('.employee_position_info_container');
    employee_position_info_container.classList.toggle('show_container');
    if (employee_position_info_container.classList.contains('show_container')) {
        localStorage.setItem('showEmployeePositionInfoContainer', 'true');
    } else {
        localStorage.removeItem('showEmployeePositionInfoContainer');
    }
});

let employee_position_list_label = document.querySelector('#employee_position_list_label');
employee_position_list_label.addEventListener("click", (e) => {
    employee_position_list_label.classList.toggle('show');
    let employee_position_list_container = document.querySelector('.employee_position_list_container');
    employee_position_list_container.classList.toggle('show_container');
    if (employee_position_list_container.classList.contains('show_container')) {
        localStorage.setItem('showEmployeePositionListContainer', 'true');
    } else {
        localStorage.removeItem('showEmployeePositionListContainer');
    }
});

new DataTable('#employee_position_list');

$("#clear").click(function() {
    $("#position_name").val('');
    $('#other_name').val('');
    $("#is_discontinued").prop('checked', false);

});


$(document).on("click", ".edit_employeePosition_modal_dialog", function() {
    var employee_position_id = $(this).data('employee_position_id');
    var position_name = $(this).data('position_name');
    var other_name = $(this).data('other_name');
    var is_discontinued = $(this).data('is_discontinued');
    $(".modal-body #edit_employee_position_id").val(employee_position_id);
    $(".modal-body #edit_position_name").val(position_name);
    $(".modal-body #edit_other_name").val(other_name);

    if (is_discontinued == 1) {
        document.getElementById("edit_employee_position_is_discontinued").checked = true;
    } else {
        document.getElementById("edit_employee_position_is_discontinued").checked = false;
    }
});

$(function() {
    $("#employeePositionEditModalForm").validate({
        rules: {
            edit_position_name: {
                required: true,
            },

        },
        messages: {
            edit_position_name: {
                required: "Position Name ဖြည့်ရန်လိုအပ်ပါသည်",
            },

        }
    });

});

$(document).on("click", ".delete_employeePosition_modal_dialog", function() {
    var employee_position_id = $(this).data('employee_position_id');
    var position_name = $(this).data('position_name');
    $(".modal-header #delete_modal_header").text("Delete '" + position_name + "'");
    $(".modal-body #delete_employee_position_id").val(employee_position_id);
});
