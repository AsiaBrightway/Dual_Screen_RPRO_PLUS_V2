$(function() {
    $.validator.addMethod(
        "checkFileExtension",
        function(value, element) {
            // Check if the file is empty
            if (value.length === 0) {
                return true; // Skip validation if the file is not provided
            }

            // Get the file extension
            var extension = value.split(".").pop().toLowerCase();

            // Check if the file extension is one of 'jpg', 'jpeg', or 'png'
            return ["jpg", "jpeg", "png"].includes(extension);
        },
        "Image သည် JPG, JPEG, PNG Format သာဖြစ်ရပါမည်"
    );

    $("#barAddModalForm").validate({
        rules: {
            bar_category_name: {
                required: true,
                minlength: 3,
            },
            bar_menu_category_image: {
                checkFileExtension: true,
            },
        },
        messages: {
            bar_category_name: {
                required: "Category Name ဖြည့်ရန်လိုအပ်ပါသည်",
                minlength: "အနည်းဆုံး၃လုံးရှိရပါမည်",
            },
        },
    });

    $("#barEditModalForm").validate({
        rules: {
            edit_bar_category_name: {
                required: true,
                minlength: 3,
            },
            edit_bar_menu_category_image: {
                checkFileExtension: true,
            },
        },
        messages: {
            edit_bar_category_name: {
                required: "Category Name ဖြည့်ရန်လိုအပ်ပါသည်",
