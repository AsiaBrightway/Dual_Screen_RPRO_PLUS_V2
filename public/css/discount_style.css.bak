.discount_info_container,
.discount_details_container,
.discount_list_container {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    /* transition: max-height 0.5s ease-out, opacity 0.5s ease-out; */
    background-color: #fff;
}

.discount_info_container.show_container,
.discount_details_container.show_container,
.discount_list_container.show_container {
    padding: 30px;
    max-height: 800px;
    opacity: 1;
    background-color: #fff;
    border-radius: 5px 5px 10px 10px;
    margin: -20px 1px 20px 1px;
    transition: max-height 0.5s ease-out, opacity 0.5s ease-out;
}

.custom_btn {
    color: #fff;
    background-color: #512DA8;
}

.custom_btn:hover {
    color: #fff;
    background-color: #6f44d1;
}

.page-discount.active .page-link {
    background-color: #6f44d1 !important;
    border: 1px solid black;
    color: #fff !important;
    font-size: 13px;
}

.page-link {
    color: black !important;
    font-size: 13px;
}

.dataTables_wrapper .row {
    padding-top: 5px;
    padding-bottom: 5px;
}

#discount_info_label,
#discount_details_label,
#discount_list_label {
    height: 40px;
    border-radius: 10px;
    margin-left: 1px;
    margin-right: 1px;
    margin-bottom: 10px
}

i {
    transition: all 0.3s ease;
}

#discount_info_label.show i.arrow,
#discount_details_label.show i.arrow,
#discount_list_label.show i.arrow {
    transform: rotate(-180deg);
}

table.dataTable thead tr th,
table.dataTable tfoot tr th {
    color: #512DA8;
}

.muted {
    background-color: #f2f2f2;
    /* Light gray background when muted */
    /* color: #808080; */
    /* Light gray text color when muted */
}