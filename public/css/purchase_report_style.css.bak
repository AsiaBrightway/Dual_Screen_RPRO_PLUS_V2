.purchase_report_container {
    height: calc(100vh - 140px);
    margin: 0;
}

.total_div {
    background-color: #fff;
    border-radius: 10px;
    margin: 0;
    margin-top: 10px;
    height: 100px;
}

.purchase_filter {
    background-color: #fff;
    border-radius: 10px;
}

.purchase_table {
    background-color: #fff;
    height: calc(100vh - 245px);
    border-radius: 10px;
}

#btn_purchase_search {
    color: #fff !important;
    background-color: #512da8 !important;
    position: fixed;
    bottom: 25px;
}

